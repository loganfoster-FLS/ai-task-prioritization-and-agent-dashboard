{
  "name": "command-dashboard",
  "version": "1.0.0",
  "description": "AI Command Dashboard",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dir": "electron-builder --mac dir"
  },
  "build": {
    "appId": "com.dashboard.command",
    "productName": "Dashboard",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "slack-oauth-bridge.html",
      "command-dashboard.html"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
